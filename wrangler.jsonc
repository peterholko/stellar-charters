{
  "$schema": "./node_modules/wrangler/config-schema.json",
  "name": "stellar-charters-claude",
  "compatibility_date": "2026-06-01",
  "workers_dev": true,
  "assets": {
    "directory": "./web/dist",
    "not_found_handling": "single-page-application"
  },
  "routes": [
    { "pattern": "stellar-charters-claude.peterholko.com", "custom_domain": true }
  ]
}
